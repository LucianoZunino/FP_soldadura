@startuml
title FP_Soldadura - Flujo operativo de datos

actor Operador
participant "Dashboard React/Vite" as Frontend
participant "API Express" as API
participant "LKN Auto Sync" as LknSync
participant "LKN Importer" as LknImporter
participant "CSV Importer" as Importer
database "MySQL\nferrosider_produccion_soldadura" as DB
database "lkn_soft\nproduccion_horaria" as Lkn
participant "CSV historico\nCSV_PATH" as CsvManual
participant "Excel articulos\nARTICLES_XLSX_PATH" as Excel

Operador -> Frontend : Abre Dashboard
activate Frontend
Frontend -> API : GET /api/dashboard?fecha=hoy
activate API
API -> DB : Consulta produccion, celdas, piezas y articulos finales
activate DB
DB --> API : Datos agregados por fecha, turno y hora
deactivate DB
API --> Frontend : Dashboard inicial
deactivate API

loop Cada LKN_SYNC_SECONDS si LKN_AUTO_SYNC_ENABLED=true
  LknSync -> LknImporter : importLknProduction(fecha=hoy)
  activate LknImporter
  LknImporter -> Lkn : Lee produccion_horaria
  Lkn --> LknImporter : Produccion por maquina/hora
  LknImporter -> DB : Consulta maquina_pieza_mapeo vigente
  DB --> LknImporter : celda + pieza por maquina
  LknImporter -> DB : Reemplaza produccion_hora del dia
  DB --> LknImporter : Datos actualizados
  deactivate LknImporter
end

loop Cada 10 segundos si fecha = hoy
  Frontend -> API : GET /api/dashboard?fecha=hoy
  activate API
  API -> DB : Consulta datos actualizados
  activate DB
  DB --> API : Matriz y totales actualizados
  deactivate DB
  API --> Frontend : Dashboard actualizado
  deactivate API
end

Operador -> Frontend : Actualizar vivo manual
Frontend -> API : POST /api/live-sync
activate API
API -> LknSync : runLknAutoSync()
LknSync -> LknImporter : importLknProduction(fecha=hoy)
LknImporter -> Lkn : Lee produccion_horaria
LknImporter -> DB : Actualiza produccion_hora
API --> Frontend : Resultado sync LKN
deactivate API

Operador -> Frontend : Importar CSV manual
Frontend -> API : POST /api/import
activate API
API -> CsvManual : Lee CSV_PATH
CsvManual --> API : CSV historico o manual
API -> Importer : importCsv(fecha seleccionada)
activate Importer
Importer -> DB : Upsert produccion_hora
DB --> Importer : OK
Importer --> API : Resumen importacion
deactivate Importer
API --> Frontend : Resultado importacion
deactivate API

Operador -> Frontend : Importar articulos
Frontend -> API : POST /api/import-articulos
activate API
API -> Excel : Lee Excel de articulos/componentes
Excel --> API : Relaciones articulo final - componente
API -> DB : Reconstruye articulo_final, pieza_articulo_final y celda_pieza_articulo_final
DB --> API : Relaciones actualizadas
API --> Frontend : Resultado importacion
deactivate API

Frontend -> API : GET /api/turno | /api/catalogos
API -> DB : Consultas auxiliares
DB --> API : Datos filtrados
API --> Frontend : Vistas Produccion, Historial, Detalle, Exportar

deactivate Frontend
@enduml
